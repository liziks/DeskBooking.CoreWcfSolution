
@model BookingIndexViewModel
@using DeskBooking.WebClient.Infrastructure

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Бронирования</h2>
    <a asp-action="Create" class="btn btn-primary">Создать</a>
</div>

<form method="get" class="row g-2 mb-4">
    <div class="col-md-3">
        <label class="form-label">С</label>
        <input type="datetime-local" name="fromLocal" value="@(Model.FromLocal?.ToString("yyyy-MM-ddTHH:mm"))" class="form-control" />
    </div>
    <div class="col-md-3">
        <label class="form-label">По</label>
        <input type="datetime-local" name="toLocal" value="@(Model.ToLocal?.ToString("yyyy-MM-ddTHH:mm"))" class="form-control" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Комната</label>
        <select name="roomId" class="form-select">
            <option value="">Все</option>
            @foreach (var room in Model.Rooms)
            {
                @if (Model.RoomId == room.Id)
            {
                <option value="@room.Id" selected="selected">@room.Name</option>
            }
            else
            {
                <option value="@room.Id">@room.Name</option>
            }
            }
        </select>
    </div>
    <div class="col-md-2 form-check mt-4 ms-3">
        <input type="checkbox" class="form-check-input" name="onlyMyBookings" value="true" @(Model.OnlyMyBookings ? "checked" : "") />
        <label class="form-check-label">Только мои</label>
    </div>
    <div class="col-md-1 mt-4">
        <button type="submit" class="btn btn-outline-primary">Фильтр</button>
    </div>
</form>

<table class="table table-bordered table-striped align-middle">
    <thead>
        <tr>
            <th>ID</th>
            <th>Комната</th>
            <th>Пользователь</th>
            <th>Тема</th>
            <th>Интервал</th>
            <th>Участники</th>
            <th>Статус</th>
            <th style="width: 220px;">Действия</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var booking in Model.Bookings)
    {
        <tr>
            <td>@booking.Id</td>
            <td>@booking.RoomName</td>
            <td>@booking.UserDisplayName</td>
            <td>@booking.Title</td>
            <td>
                @DateTimeLocalHelper.ToLocal(booking.StartUtc).ToString("dd.MM.yyyy HH:mm")
                -
                @DateTimeLocalHelper.ToLocal(booking.EndUtc).ToString("dd.MM.yyyy HH:mm")
            </td>
            <td>@booking.ParticipantCount</td>
            <td>@booking.Status</td>
            <td>
                @if (booking.Status.ToString() != "Cancelled")
                {
                    <a asp-action="Edit" asp-route-id="@booking.Id" class="btn btn-sm btn-outline-secondary">Изменить</a>
                    <form asp-action="Cancel" asp-route-id="@booking.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('Отменить бронирование?');">
                            Отменить
                        </button>
                    </form>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
