
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>DeskBooking</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" asp-controller="Rooms" asp-action="Index">DeskBooking</a>

            @if (Context.Session.GetString("SessionToken") is not null)
            {
                <div class="navbar-nav me-auto">
                    <a class="nav-link" asp-controller="Rooms" asp-action="Index">Рабочие места</a>
                    <a class="nav-link" asp-controller="Bookings" asp-action="Index">Бронирования</a>
                    <a class="nav-link" asp-controller="Bookings" asp-action="Availability">Поиск доступных</a>
                </div>

                <div class="d-flex align-items-center gap-3">
                    <span class="text-light">
                        @Context.Session.GetString("DisplayName")
                        (@Context.Session.GetString("UserRole"))
                    </span>
                    <form asp-controller="Auth" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-light btn-sm">Выйти</button>
                    </form>
                </div>
            }
        </div>
    </nav>

    <div class="container">
        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="alert alert-success">@successMessage</div>
        }

        @if (TempData["ErrorMessage"] is string errorMessage)
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        @RenderBody()
    </div>
</body>
</html>
